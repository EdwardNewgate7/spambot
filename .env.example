# Telegram API Credentials
# Get these from https://my.telegram.org
API_ID=123456
API_HASH=your_api_hash_here

# Bot Owner User IDs (Space separated)
# Example: SUDO=123456789 987654321
SUDO=

# Telegram Session Strings (Pyrogram/Telethon String Sessions)
# You can generate these using a session generator bot or script.
# Add as many as needed (STRING, STRING2, STRING3...)
STRING=
STRING2=
STRING3=
# ...
